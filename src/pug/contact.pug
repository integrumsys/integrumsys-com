doctype html
html(lang="en")
    head
        meta(charset="utf-8")
        meta(name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no")
        meta(
            name="description"
            content="Get in touch with Integrum Systems. Direct inquiries, project scoping, and technical questions welcome. Email: contact@integrumsys.com."
        )
        meta(name="author" content="Integrum Systems")

        title Contact — Integrum Systems

        // Favicon
        link(rel="icon" type="image/x-icon" href="assets/favicon.ico")

        include includes/css.pug

    body.d-flex.flex-column.h-100
        main.flex-shrink-0
            // Navigation
            include includes/navbar.pug

            // Page header
            header.bg-fog.py-5.border-bottom
                .container.py-4(style="max-width: 1200px")
                    .row.justify-content-center
                        .col-lg-8.text-center
                            h1.display-6.fw-bolder.mb-3 Get in touch.
                            p.lead.mb-0
                                | Direct inquiries, project scoping, and technical questions welcome. We respond to every message.

            // Contact section
            section.py-5
                .container.py-4(style="max-width: 1200px")
                    .row.justify-content-center
                        .col-lg-7
                            // Direct email notice
                            .alert.mb-4(style="background-color: #e6f7f8; border: 1px solid #0e9aa7; color: #0b1220")
                                | Form submission is being set up. Reach us directly at&nbsp;
                                a.fw-500(href="mailto:contact@integrumsys.com" style="color: #0b7f89") contact@integrumsys.com

                            // Contact form
                            form(action="mailto:contact@integrumsys.com" method="GET")
                                // Name
                                .form-floating.mb-3
                                    input#name.form-control(type="text" placeholder="Full name" required)
                                    label(for="name") Full name

                                // Email
                                .form-floating.mb-3
                                    input#email.form-control(type="email" placeholder="name@example.com" required)
                                    label(for="email") Email address

                                // Phone (optional)
                                .form-floating.mb-3
                                    input#phone.form-control(type="tel" placeholder="Phone number (optional)")
                                    label(for="phone") Phone number (optional)

                                // Message
                                .form-floating.mb-4
                                    textarea#message.form-control(placeholder="Message" required style="height: 10rem")
                                    label(for="message") Message

                                .d-grid
                                    button.btn.btn-primary.btn-lg(type="submit") Send message

                            // Direct contact
                            hr.my-4(style="border-color: #d7dee8")
                            p.mb-1
                                span.font-mono.small(style="color: #3b4a5e") Email
                                |
                                | &nbsp;
                                a(href="mailto:contact@integrumsys.com") contact@integrumsys.com
                            p.mb-0.text-muted.small Based in Canada.

        // Footer
        include includes/footer.pug

        include includes/scripts.pug
